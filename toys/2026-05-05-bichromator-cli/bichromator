#!/usr/bin/env python3
"""bichromator — colour English prose by Latinate vs Germanic root.

Reads prose from stdin or file and emits colored output to stdout,
with summary stats to stderr. Words are colored in ANSI:
  - burnt-sienna for Germanic roots
  - lapis blue for Latinate
  - dim grey for uncertain
  - bright versions for high-confidence matches

Summary line gives counts and G:L ratio (register fingerprint).
Classifier is heuristic (suffix/prefix rules + wordlists), not a dictionary.

Companion tools:
  - ../2026-05-05-prose-bichromator/  (HTML, interactive, same classifier)
  - ../2026-05-09-bichromator-concrete/  (HTML, concreteness dimension)

See README.md for more.
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

# ── ANSI ──────────────────────────────────────────────────────────────
_RESET = "\033[0m"
_BOLD = "\033[1m"
# 256-colour codes that approximate the HTML toy's palette
_GERMANIC = "\033[38;5;130m"   # burnt sienna ≈ #af5f00
_LATINATE = "\033[38;5;25m"    # lapis blue ≈ #005faf
_UNKNOWN = "\033[38;5;244m"    # dim grey
_GERMANIC_STRONG = "\033[1;38;5;166m"
_LATINATE_STRONG = "\033[1;38;5;26m"

