_SUFFIX_LATINATE = re.compile(
    r"(tion|sion|ment|ance|ence|ity|ate|ize|ise|ous|ive|ify|ical|ically|"
    r"esque|ation|itude|escence|escent|ology|ologist|arian|ician|atious)$"
)
_SUFFIX_GERMANIC = re.compile(
    r"(ness|hood|ship|dom|ling|lock|ward|wards|like|ful|less|some|ish|en|ing)$"
)
_PREFIX_LATINATE = re.compile(
    r"^(con|com|pre|pro|trans|inter|retro|ultra|post|sub|super|anti|contra|"
    r"extra|intra|circum|ex|dis|non|mal|bene|semi|multi|omni|equi|magni|uni|bi|tri|quadri)"
)
_PREFIX_GERMANIC = re.compile(r"^(be|un|mis|over|under|out|fore|after|by)")


def classify(raw: str) -> tuple[str, int]:
    w = re.sub(r"[^a-z']", "", raw.lower())
    if not w or len(w) < 2:
        return "unknown", 0
    if w in GERMANIC_CORE:
        return "germanic", 1
    if w in LATINATE_CORE:
        return "latinate", 1

    score = 0
    if _SUFFIX_LATINATE.search(w):
        score += 2
    if _SUFFIX_GERMANIC.search(w):
        score -= 2
    if _PREFIX_LATINATE.search(w):
        score += 1
    if _PREFIX_GERMANIC.search(w):
        score -= 1
    if len(w) >= 9:
        score += 1
    if len(w) <= 4:
        score -= 1
    if re.search(r"tion|sion|cious|tious|ique", w):
        score += 2
    if re.search(r"th|ght|ck|wh|kn", w):
        score -= 1
    if re.search(r"ph|ch[oae]", w):
        score += 1

    if score >= 2:
        return "latinate", 1 if score >= 3 else 0
    if score <= -2:
        return "germanic", 1 if score <= -3 else 0
    return "unknown", 0


def colorize(text: str, *, no_color: bool = False) -> tuple[str, dict[str, int]]:
    counts = {"germanic": 0, "latinate": 0, "unknown": 0}
    out: list[str] = []
    for tok in re.split(r"(\s+|[^\sa-zA-Z']+)", text):
        if not tok:
            continue
        if tok.isspace() or not re.match(r"^[a-zA-Z']+$", tok):
            out.append(tok)
            continue
        cls, strong = classify(tok)
        counts[cls] += 1
        if no_color:
            out.append(tok)
            continue
        if cls == "germanic":
            out.append((_GERMANIC_STRONG if strong else _GERMANIC) + tok + _RESET)
        elif cls == "latinate":
            out.append((_LATINATE_STRONG if strong else _LATINATE) + tok + _RESET)
        else:
            out.append(_UNKNOWN + tok + _RESET)
    return "".join(out), counts


def _summary(counts: dict[str, int], *, no_color: bool) -> str:
    g, l, u = counts["germanic"], counts["latinate"], counts["unknown"]
    total = g + l + u
    if total == 0:
        return ""
    pct = lambda n: f"{100*n/total:5.1f}%"
    ratio = f"{g/l:.2f}" if l else "∞"
    if no_color:
        return (
            f"\n— {g} Germanic ({pct(g)})  {l} Latinate ({pct(l)})  "
            f"{u} uncertain ({pct(u)})  G:L = {ratio}"
        )
    return (
        f"\n{_BOLD}— {_GERMANIC}{g} Germanic{_RESET} ({pct(g)})  "
        f"{_LATINATE}{l} Latinate{_RESET} ({pct(l)})  "
        f"{_UNKNOWN}{u} uncertain{_RESET} ({pct(u)})  "
        f"{_BOLD}G:L = {ratio}{_RESET}"
    )


def main() -> int:
    args = sys.argv[1:]
    no_color = "--no-color" in args or not sys.stdout.isatty()
    args = [a for a in args if a != "--no-color"]
    if "--help" in args or "-h" in args:
        print(__doc__, file=sys.stderr)
        print("\nUsage:", file=sys.stderr)
        print("  bichromator [FILE]           — read FILE, emit colored output to stdout + stats to stderr", file=sys.stderr)
        print("  bichromator -                — read stdin (also the default if no file given)", file=sys.stderr)
        print("  bichromator FILE --no-color  — suppress ANSI codes (for piping)", file=sys.stderr)
        print("\nExamples:", file=sys.stderr)
        print("  cat essay.md | bichromator", file=sys.stderr)
        print("  bichromator essay.md > colored.txt 2> stats.txt", file=sys.stderr)
        return 0
    if args and args[0] != "-":
        try:
            text = Path(args[0]).read_text(encoding="utf-8")
        except OSError as e:
            print(f"bichromator: {e}", file=sys.stderr)
            return 1
    else:
        text = sys.stdin.read()
    coloured, counts = colorize(text, no_color=no_color)
    print(coloured, end="")
    if not coloured.endswith("\n"):
        print()
    print(_summary(counts, no_color=no_color), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
